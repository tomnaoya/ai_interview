# ── .env.example ─────────────────────────────────────────────────
# Rename to .env for local development

# Anthropic API Key (required)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# JWT Secret Key (generate random string for production)
SECRET_KEY=your-super-secret-key-change-this

# Admin credentials (initial setup)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin1234!

# Data directory (Render disk: /mnt/data, local: ./data)
DATA_DIR=./data

# Database URL (defaults to SQLite in DATA_DIR)
# For PostgreSQL: postgresql://user:password@host:5432/dbname
# DATABASE_URL=sqlite:///./data/ai_interview.db
